# ─── Server ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# Secret used to sign Better Auth sessions — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-a-random-secret

# Public URL of the server (used by Better Auth for redirects / cookie domain)
BETTER_AUTH_URL=http://localhost:3000

# Allowed origin for CORS (your Vite dev server)
CLIENT_URL=http://localhost:5173

# Google Gemini API key — obtain at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use for chat completions
CHAT_MODEL=gemini-2.5-flash

# Gemini model to use for text embeddings
EMBEDDING_MODEL=text-embedding-004

# ─── Optional SMTP (for email-based auth / magic links) ───────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=no-reply@example.com

# ─── Client ───────────────────────────────────────────────────────────────────

# Base URL of the Express API server (consumed by Vite via import.meta.env)
VITE_API_URL=http://localhost:3000
